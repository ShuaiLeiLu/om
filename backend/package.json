    "@nestjs/schedule": "^6.0.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.19.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.65.1",
    "cookie-parser": "^1.4.7",
    "ioredis": "^5.8.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^13.0.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.14",
