NODE_ENV=development
PORT=3001
APP_ORIGIN=https://aihelp.shuai.help
DATABASE_URL=postgresql://chatty_backend:CHANGE_ME@postgresSQL:5432/chatty_backend?schema=public
REDIS_URL=redis://redis:6379/2
COOKIE_SECRET=change-me-cookie-secret
ADMIN_SESSION_SECRET=change-me-admin-session-secret
USER_SESSION_SECRET=change-me-user-session-secret
WECHAT_MINIAPP_APP_ID=
WECHAT_MINIAPP_APP_SECRET=
WECHAT_MINIAPP_PAGE_PATH=pages/index/index
WECHAT_MINIAPP_ENV_VERSION=release
WECHAT_REWARDED_VIDEO_AD_UNIT_ID=

# 微信开放平台「网站应用」（用于 PC 一键登录，scope=snsapi_login）
# 在 https://open.weixin.qq.com 申请「网站应用」获得 AppID / AppSecret，
# 并在「授权回调域」里登记 APP_ORIGIN 的域名（不含 https:// 与路径）。
WECHAT_OPEN_APP_ID=
WECHAT_OPEN_APP_SECRET=
# 必须与开放平台后台「授权回调域」匹配的完整 URL
WECHAT_OPEN_REDIRECT_URI=https://aihelp.shuai.help/api/auth/wechat/oauth/callback
# 可选：公众号网页授权（用于微信内置浏览器 H5 一键登录，scope=snsapi_userinfo）
# 留空则回退到开放平台的 AppID/Secret（仅当公众号与网站应用使用同一套时可用）
WECHAT_OFFIACCOUNT_APP_ID=
WECHAT_OFFIACCOUNT_APP_SECRET=
# OAuth state token 有效期（秒），默认 600
WECHAT_OAUTH_STATE_TTL_SECONDS=600
# state 签名使用的密钥；留空则复用 COOKIE_SECRET
WECHAT_OAUTH_STATE_SECRET=
SUB2API_BASE_URL=http://sub2api:8080
SUB2API_GATEWAY_API_KEY=
# Optional dedicated image gateway key. Use this when the text key pool includes
# groups that do not allow image generation.
SUB2API_IMAGE_GATEWAY_API_KEY=

# MinIO / S3-compatible object storage
# Tencent Cloud current MinIO container exposes API on host port 9000.
# If backend and minio are not on the same Docker network, use a host/public endpoint.
MINIO_ENDPOINT=http://43.155.204.215:9000
MINIO_PUBLIC_ENDPOINT=https://files.aihelp.shuai.help
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=cyber-invest
MINIO_FORCE_PATH_STYLE=true

# Image storage
IMAGE_BACKEND=minio
IMAGE_PRESIGN_TTL_SECONDS=21600
IMAGE_UPLOAD_MAX_BYTES=26214400
IMAGE_USER_STORAGE_DEFAULT_BYTES=0
IMAGE_GC_DRY_RUN=false
IMAGE_GC_OLDER_THAN_HOURS=24
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=admin@123

# 邮件发送服务（SMTP）— 用于邮箱验证、密码找回
# 示例 1：阿里云企业邮箱 / QQ 企业邮箱
#   SMTP_HOST=smtp.exmail.qq.com   SMTP_PORT=465   SMTP_SECURE=true
# 示例 2：Gmail
#   SMTP_HOST=smtp.gmail.com   SMTP_PORT=587   SMTP_SECURE=false  （需启用应用专用密码）
# 示例 3：自建 Postfix
#   SMTP_HOST=mail.example.com   SMTP_PORT=587   SMTP_SECURE=false
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
# From 格式：可写 "万模AI <noreply@example.com>" 或裸邮箱
SMTP_FROM=
# 邮件主题前缀（可选），用于让收件箱里更容易识别
SMTP_SUBJECT_PREFIX=万模AI
# 验证码 TTL（秒），默认 600
EMAIL_VERIFICATION_TTL_SECONDS=600
# 单封邮箱重发间隔（秒），防止刷邮件
EMAIL_VERIFICATION_RESEND_INTERVAL_SECONDS=60
# 单 IP 每小时最多发码次数
EMAIL_VERIFICATION_IP_HOURLY_LIMIT=20
# 单个验证码最大尝试次数
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
