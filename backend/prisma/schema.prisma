generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  disabled
}

enum AdminRole {
  admin
  owner
}

enum SessionStatus {
  active
  revoked
}

enum QrSessionMode {
  login
  login_code
}

enum QrSessionStatus {
  pending
  scanned
  confirmed
  expired
  cancelled
  failed
}

enum PlanStatus {
  active
  disabled
}

enum RedeemCodeStatus {
  unused
  used
  revoked
  expired
}

enum TokenGrantSource {
  redeem_code
  ad_reward
  manual_adjustment
}

enum TokenGrantStatus {
  active
  exhausted
  expired
  revoked
}

enum QuotaLedgerType {
  redeem_code
  ad_reward
  manual_adjustment
  model_usage
  grant_expired
  refund
}

enum ConversationStatus {
  active
  deleted
}

enum MessageRole {
  user
  assistant
  system
}

enum MessageStatus {
  pending
  completed
  failed
  cancelled
}

enum LlmRequestStatus {
  pending
  streaming
  completed
  failed
  cancelled
}

enum UsageEventStatus {
  matched
  unmatched
  charged
  ignored
}

enum RewardSessionStatus {
  pending
  granted
  expired
  rejected
}

enum ImageSource {
  upload
  generated
  system
}

enum VerificationPurpose {
  register
  reset_password
  bind_email
}

enum VerificationStatus {
  active
  consumed
  expired
  exhausted
}

model EmailVerificationCode {
  id          String              @id @default(uuid())
  email       String
  purpose     VerificationPurpose
  codeHash    String
  status      VerificationStatus  @default(active)
  attempts    Int                 @default(0)
  maxAttempts Int                 @default(5)
  ip          String              @default("")
  userAgent   String              @default("")
  createdAt   DateTime            @default(now())
  expiresAt   DateTime
  consumedAt  DateTime?
  @@index([email, purpose, status])
  @@index([createdAt])
}

enum ImageTaskMode {
  generate
  edit
}

enum ImageTaskStatus {
  pending
  running
  done
  failed
  canceled
}

model User {
  id              String                 @id @default(uuid())
  displayName     String                 @default("")
  avatarUrl       String                 @default("")
  email           String?                @unique
  passwordHash    String?
  emailVerifiedAt DateTime?
  status          UserStatus             @default(active)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  lastLoginAt     DateTime?
  oauthAccounts   OauthAccount[]
  sessions        UserSession[]
  qrSessions     WechatQrSession[]
  miniSessions   WechatMiniappSession[]
  tokenGrants    TokenGrant[]
  quotaLedger    QuotaLedger[]
  conversations  Conversation[]
  messages       Message[]
  llmRequests    LlmRequest[]
  usageEvents    UsageEvent[]
  rewardSessions AdRewardSession[]
  rewardEvents   AdRewardEvent[]
  ownedImages    Image[]
  imageTasks     ImageTask[]
  storageUsage   StorageUsage?
  imageRefs      UserImageRef[]
}

model AdminUser {
  id           String          @id @default(uuid())
  username     String          @unique
  email        String          @unique
  passwordHash String
  role         AdminRole       @default(admin)
  status       UserStatus      @default(active)
  lastLoginAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  auditLogs    AdminAuditLog[]
  sessions     AdminSession[]
}

model AdminSession {
  id               String        @id @default(uuid())
  adminUserId      String
  refreshTokenHash String        @unique
  status           SessionStatus @default(active)
  expiresAt        DateTime
  createdAt        DateTime      @default(now())
  revokedAt        DateTime?
  ip               String        @default("")
  userAgent        String        @default("")
  adminUser        AdminUser     @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
}

model OauthAccount {
  id          String    @id @default(uuid())
  userId      String
  provider    String
  appid       String
  openid      String
  unionid     String?
  nickname    String    @default("")
  avatarUrl   String    @default("")
  boundAt     DateTime  @default(now())
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, appid, openid])
  @@index([unionid])
  @@index([userId])
}

model UserSession {
  id               String        @id @default(uuid())
  userId           String
  refreshTokenHash String
  status           SessionStatus @default(active)
  expiresAt        DateTime
  createdAt        DateTime      @default(now())
  revokedAt        DateTime?
  ip               String        @default("")
  userAgent        String        @default("")
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshTokenHash])
}

model WechatQrSession {
  id          String          @id @default(uuid())
  sessionId   String          @unique
  mode        QrSessionMode   @default(login)
  scene       String          @unique
  status      QrSessionStatus @default(pending)
  userId      String?
  openid      String?
  unionid     String?
  loginCode   String?
  expiresAt   DateTime
  scannedAt   DateTime?
  confirmedAt DateTime?
  createdAt   DateTime        @default(now())
  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([scene])
  @@index([status])
  @@index([loginCode, mode, status])
}

model WechatMiniappSession {
  id               String    @id @default(uuid())
  sessionTokenHash String    @unique
  openid           String
  unionid          String?
  userId           String?
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  revokedAt        DateTime?
  user             User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([openid])
  @@index([userId])
}

model Plan {
  id          String       @id @default(uuid())
  name        String
  tokenAmount BigInt
  validDays   Int
  modelScope  Json?
  status      PlanStatus   @default(active)
  remark      String       @default("")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  redeemCodes RedeemCode[]
}

model RedeemCode {
  id               String           @id @default(uuid())
  codeHash         String           @unique
  planId           String
  status           RedeemCodeStatus @default(unused)
  expiresAt        DateTime?
  usedByUserId     String?
  usedAt           DateTime?
  createdByAdminId String?
  createdAt        DateTime         @default(now())
  revokedAt        DateTime?
  plan             Plan             @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([planId])
  @@index([status])
}

model TokenGrant {
  id              String           @id @default(uuid())
  userId          String
  source          TokenGrantSource
  sourceId        String?
  totalTokens     BigInt
  remainingTokens BigInt
  startsAt        DateTime         @default(now())
  expiresAt       DateTime
  status          TokenGrantStatus @default(active)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledger          QuotaLedger[]

  @@index([userId, status, expiresAt])
}

model QuotaLedger {
  id           String          @id @default(uuid())
  userId       String
  grantId      String?
  type         QuotaLedgerType
  deltaTokens  BigInt
  balanceAfter BigInt
  relatedId    String?
  remark       String          @default("")
  createdAt    DateTime        @default(now())
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  grant        TokenGrant?     @relation(fields: [grantId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([relatedId])
}

model Conversation {
  id             String             @id @default(uuid())
  userId         String
  title          String             @default("新对话")
  defaultModelId String?
  status         ConversationStatus @default(active)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages       Message[]
  llmRequests    LlmRequest[]
  imageTasks     ImageTask[]

  @@index([userId, updatedAt])
}

model Message {
  id             String        @id @default(uuid())
  conversationId String
  userId         String
  role           MessageRole
  content        String        @default("")
  imagesJson     Json?
  modelId        String?
  status         MessageStatus @default(completed)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model LlmRequest {
  id               String           @id @default(uuid())
  requestId        String           @unique
  userId           String
  conversationId   String?
  modelId          String
  sub2apiRequestId String?
  status           LlmRequestStatus @default(pending)
  errorMessage     String?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime         @default(now())
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation     Conversation?    @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  usageEvents      UsageEvent[]
  imageTask        ImageTask?       @relation("ImageTaskLlmRequest")

  @@index([userId, createdAt])
  @@index([sub2apiRequestId])
}

model UsageEvent {
  id               String           @id @default(uuid())
  sub2apiUsageId   String           @unique
  llmRequestId     String?
  userId           String?
  modelId          String?
  promptTokens     BigInt           @default(0)
  completionTokens BigInt           @default(0)
  totalTokens      BigInt           @default(0)
  cost             Decimal          @default(0) @db.Decimal(18, 8)
  rawJson          Json
  status           UsageEventStatus @default(unmatched)
  syncedAt         DateTime         @default(now())
  createdAt        DateTime         @default(now())
  request          LlmRequest?      @relation(fields: [llmRequestId], references: [id], onDelete: SetNull)
  user             User?            @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([llmRequestId])
}

model ModelConfig {
  id           String   @id @default(uuid())
  provider     String
  displayName  String
  sub2apiModel String   @unique
  enabled      Boolean  @default(true)
  sortOrder    Int      @default(0)
  remark       String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Image {
  id          String            @id @default(uuid())
  hash        String            @unique
  bucket      String
  objectKey   String
  contentType String
  bytes       Int
  width       Int?
  height      Int?
  source      ImageSource       @default(generated)
  ownerUserId String?
  refCount    Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  owner       User?             @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  taskInputs  ImageTaskInput[]
  taskOutputs ImageTaskOutput[]
  userRefs    UserImageRef[]

  @@index([ownerUserId, createdAt])
}

model ImageTask {
  id               String            @id @default(uuid())
  userId           String
  conversationId   String?
  mode             ImageTaskMode
  modelId          String
  prompt           String
  paramsJson       Json
  status           ImageTaskStatus   @default(pending)
  error            String?
  requestId        String            @unique
  sub2apiRequestId String?
  startedAt        DateTime?
  finishedAt       DateTime?
  durationMs       Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation     Conversation?     @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  inputs           ImageTaskInput[]
  outputs          ImageTaskOutput[]
  llmRequest       LlmRequest?       @relation("ImageTaskLlmRequest", fields: [requestId], references: [requestId], onDelete: NoAction)

  @@index([userId, createdAt])
  @@index([userId, status])
}

model ImageTaskInput {
  id      String    @id @default(uuid())
  taskId  String
  imageId String
  ordinal Int
  task    ImageTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  image   Image     @relation(fields: [imageId], references: [id], onDelete: Restrict)

  @@unique([taskId, ordinal])
  @@index([imageId])
}

model ImageTaskOutput {
  id            String    @id @default(uuid())
  taskId        String
  imageId       String
  ordinal       Int
  revisedPrompt String?
  task          ImageTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  image         Image     @relation(fields: [imageId], references: [id], onDelete: Restrict)

  @@unique([taskId, ordinal])
  @@index([imageId])
}

model StorageUsage {
  userId      String   @id
  bytesTotal  BigInt   @default(0)
  imagesCount Int      @default(0)
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserImageRef {
  userId  String
  imageId String
  count   Int    @default(0)
  bytes   Int
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  image   Image  @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@id([userId, imageId])
  @@index([userId])
  @@index([imageId])
}

model AdRewardConfig {
  id                   String   @id @default(uuid())
  enabled              Boolean  @default(false)
  adUnitId             String   @default("")
  rewardTokens         BigInt   @default(10)
  dailyLimitPerUser    Int      @default(5)
  rewardTokenValidDays Int      @default(7)
  minIntervalSeconds   Int      @default(30)
  sessionTtlSeconds    Int      @default(300)
  updatedByAdminId     String?
  updatedAt            DateTime @updatedAt
  createdAt            DateTime @default(now())
}

model AdRewardSession {
  id              String              @id @default(uuid())
  rewardSessionId String              @unique
  userId          String
  openid          String
  adUnitId        String
  rewardTokens    BigInt
  status          RewardSessionStatus @default(pending)
  expiresAt       DateTime
  grantedAt       DateTime?
  createdAt       DateTime            @default(now())
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  events          AdRewardEvent[]

  @@index([userId, createdAt])
  @@index([openid, createdAt])
}

model AdRewardEvent {
  id              String           @id @default(uuid())
  rewardSessionId String?
  userId          String?
  openid          String?
  eventType       String
  result          String
  errorCode       String?
  ip              String           @default("")
  userAgent       String           @default("")
  createdAt       DateTime         @default(now())
  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  rewardSession   AdRewardSession? @relation(fields: [rewardSessionId], references: [rewardSessionId], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([rewardSessionId])
}

model SyncState {
  id            String    @id @default(uuid())
  name          String    @unique
  cursor        String?
  lastSuccessAt DateTime?
  lastError     String?
  updatedAt     DateTime  @updatedAt
}

model AdminAuditLog {
  id          String     @id @default(uuid())
  adminUserId String?
  action      String
  targetType  String
  targetId    String?
  beforeJson  Json?
  afterJson   Json?
  ip          String     @default("")
  userAgent   String     @default("")
  createdAt   DateTime   @default(now())
  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([adminUserId, createdAt])
  @@index([targetType, targetId])
}
