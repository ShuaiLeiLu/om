/* 全局主题 — 简洁亮色 */
page {
  background: #f5f5f5;
  color: #1a1a1a;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  line-height: 1.55;
  min-height: 100vh;
}

button::after {
  border: none;
}

button {
  background: transparent;
  border: none;
  padding: 0;
  margin: 0;
  line-height: 1;
}

/* 文本 */
.text-primary { color: #1a1a1a; }
.text-secondary { color: #666666; }
.text-tertiary { color: #999999; }
.text-accent { color: #4f7cff; }

.text-xs { font-size: 20rpx; }
.text-sm { font-size: 24rpx; }
.text-base { font-size: 28rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 40rpx; }
.text-2xl { font-size: 56rpx; }
.text-3xl { font-size: 72rpx; }

.font-medium { font-weight: 500; }
.font-semibold { font-weight: 600; }
.font-bold { font-weight: 700; }

/* 间距 */
.mt-1 { margin-top: 8rpx; }
.mt-2 { margin-top: 16rpx; }
.mt-3 { margin-top: 24rpx; }
.mt-4 { margin-top: 32rpx; }
.mt-5 { margin-top: 40rpx; }

/* 页面布局 */
.page {
  padding: 24rpx 32rpx 200rpx;
  box-sizing: border-box;
  min-height: 100vh;
}

.page-header {
  padding: 8rpx 0 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.section-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 通用行 */
.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.flex-1 { flex: 1; min-width: 0; }

/* 分割线 */
.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 0 32rpx;
}
