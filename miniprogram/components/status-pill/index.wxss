.pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.pill--success {
  background: #f0faf4;
  color: #1a9d5a;
}

.pill--warning {
  background: #fef7ed;
  color: #c87f2a;
}

.pill--danger {
  background: #fff0f0;
  color: #e54545;
}

.pill--info {
  background: #f0f4ff;
  color: #4f7cff;
}

.pill--neutral {
  background: #f5f5f5;
  color: #999999;
}
