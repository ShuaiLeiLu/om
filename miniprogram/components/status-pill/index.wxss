.pill {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 600;
  border-width: 1rpx;
  border-style: solid;
  letter-spacing: 0.5rpx;
}

.pill--success {
  background: rgba(16, 185, 129, 0.08);
  border-color: rgba(16, 185, 129, 0.2);
  color: #34d399;
  box-shadow: 0 0 12rpx rgba(16, 185, 129, 0.1);
}

.pill--warning {
  background: rgba(245, 158, 11, 0.08);
  border-color: rgba(245, 158, 11, 0.2);
  color: #fbbf24;
  box-shadow: 0 0 12rpx rgba(245, 158, 11, 0.1);
}

.pill--danger {
  background: rgba(239, 68, 68, 0.08);
  border-color: rgba(239, 68, 68, 0.2);
  color: #f87171;
  box-shadow: 0 0 12rpx rgba(239, 68, 68, 0.1);
}

.pill--info {
  background: rgba(99, 102, 241, 0.08);
  border-color: rgba(99, 102, 241, 0.2);
  color: #818cf8;
  box-shadow: 0 0 12rpx rgba(99, 102, 241, 0.1);
}

.pill--neutral {
  background: rgba(255, 255, 255, 0.04);
  border-color: rgba(255, 255, 255, 0.08);
  color: #9ca3af;
}

