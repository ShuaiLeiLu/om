.tb-inner {
  position: relative;
}

.tb-label {
  font-size: 24rpx;
  color: #9ca3af;
  font-weight: 500;
  letter-spacing: 1rpx;
  text-transform: uppercase;
}

.tb-value {
  margin-top: 16rpx;
  font-size: 88rpx;
  font-weight: 800;
  line-height: 1.05;
  letter-spacing: -2rpx;
  background: linear-gradient(135deg, #ffffff 0%, #e9d5ff 50%, #c7d2fe 100%);
  -webkit-background-clip: text;
  background-clip: text;
  color: transparent;
  display: inline-block;
}

.tb-caption {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #6b7280;
  letter-spacing: 0.5rpx;
}

