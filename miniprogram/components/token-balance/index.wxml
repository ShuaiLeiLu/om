<glass-card intensity="normal" padding="44rpx 40rpx" radius="40rpx" glow="{{true}}">
  <view class="tb-inner tb-inner--{{tone}}">
    <view class="tb-label">{{label}}</view>
    <view class="tb-value">{{balance}}</view>
    <view class="tb-caption">{{caption}}</view>
    <view class="tb-glow"></view>
  </view>
</glass-card>
