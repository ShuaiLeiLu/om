.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  font-weight: 500;
  position: relative;
  overflow: hidden;
  transition: opacity 0.15s ease;
  line-height: 1;
}

.btn:active {
  opacity: 0.7;
}

.btn.btn--disabled {
  opacity: 0.4;
}

.btn--block {
  display: flex;
  width: 100%;
}

/* sizes */
.btn--sm { font-size: 24rpx; padding: 16rpx 28rpx; min-height: 56rpx; border-radius: 12rpx; }
.btn--md { font-size: 28rpx; padding: 22rpx 36rpx; min-height: 80rpx; border-radius: 16rpx; }
.btn--lg { font-size: 30rpx; padding: 28rpx 44rpx; min-height: 96rpx; border-radius: 20rpx; }

/* primary - 主色实心 */
.btn--primary {
  background: #1a1a1a;
  color: #ffffff;
}

/* emerald - 绿色实心 */
.btn--emerald {
  background: #1a1a1a;
  color: #ffffff;
}

/* danger - 红色文字 */
.btn--danger {
  background: #fff0f0;
  color: #e54545;
}

/* ghost - 灰色边框 */
.btn--ghost {
  background: #ffffff;
  border: 1rpx solid #e5e5e5;
  color: #666666;
}

.btn-inner {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  line-height: 1;
}

.btn-icon {
  font-size: 28rpx;
  line-height: 1;
}
