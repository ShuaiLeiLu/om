.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-weight: 600;
  position: relative;
  overflow: hidden;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  line-height: 1;
  border: none;
  box-sizing: border-box;
}

.btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.btn.btn--disabled {
  opacity: 0.45;
  transform: none !important;
  pointer-events: none;
}

.btn--block {
  display: flex;
  width: 100%;
}

/* sizes */
.btn--sm { font-size: 24rpx; padding: 18rpx 32rpx; min-height: 64rpx; border-radius: 16rpx; }
.btn--md { font-size: 28rpx; padding: 24rpx 40rpx; min-height: 88rpx; border-radius: 20rpx; }
.btn--lg { font-size: 30rpx; padding: 30rpx 48rpx; min-height: 104rpx; border-radius: 24rpx; }

/* primary - 品牌炫彩渐变 */
.btn--primary {
  background: linear-gradient(135deg, #6366f1 0%, #a855f7 50%, #ec4899 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(168, 85, 247, 0.25);
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.15);
}

/* emerald - 绿色渐变 */
.btn--emerald {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.2);
}

/* danger - 半透明红玻璃 */
.btn--danger {
  background: rgba(239, 68, 68, 0.12);
  border: 1rpx solid rgba(239, 68, 68, 0.3);
  color: #f87171;
}

/* ghost - 半透明白玻璃 */
.btn--ghost {
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  color: #e5e7eb;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.btn-inner {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  line-height: 1;
}

.btn-icon {
  font-size: 30rpx;
  line-height: 1;
}

