<view class="container">
  <!-- User Profile Header -->
  <view class="profile-header">
    <view class="avatar-box">
      <image class="avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
    </view>
    <view class="user-info">
      <view class="nickname">{{userInfo.nickname || '微信用户'}}</view>
      <view class="user-id">ID: {{userInfo.id || '---'}}</view>
    </view>
  </view>

  <!-- Balance Bar -->
  <view class="card balance-bar" bindtap="goToLedger">
    <view class="balance-left">
      <text class="label">Token 余额</text>
      <text class="value">{{userInfo.tokenBalance || 0}}</text>
    </view>
    <view class="balance-right">
      <text>明细</text>
      <text class="arrow">></text>
    </view>
  </view>

  <!-- Menu List -->
  <view class="card menu-list">
    <view class="menu-item" bindtap="goToRedeem">
      <view class="menu-left">
        <text>使用兑换码</text>
      </view>
      <text class="arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToHelp">
      <view class="menu-left">
        <text>使用规则</text>
      </view>
      <text class="arrow">></text>
    </view>
    <view class="menu-item">
      <button class="contact-btn" open-type="contact">
        <view class="menu-left">
          <text>联系客服</text>
        </view>
        <text class="arrow">></text>
      </button>
    </view>
  </view>

  <view class="card menu-list">
    <view class="menu-item" bindtap="goToAgreement">
      <view class="menu-left">
        <text>用户协议与隐私政策</text>
      </view>
      <text class="arrow">></text>
    </view>
  </view>

  <view class="logout-box" bindtap="logout">
    <text>退出登录</text>
  </view>

  <view class="version">Version 1.0.0</view>
</view>
