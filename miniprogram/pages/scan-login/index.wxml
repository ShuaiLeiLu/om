<view class="page">
  <view class="page-header">
    <view class="section-title">网页登录</view>
  </view>

  <!-- 状态区域 -->
  <view class="status-area">
    <view class="status-icon status-icon--{{status}}">
      <text wx:if="{{status === 'confirmed'}}">✓</text>
      <text wx:elif="{{status === 'failed'}}">×</text>
      <view wx:else class="spinner"></view>
    </view>
    <view class="status-text">{{statusText}}</view>
    <view wx:if="{{errorText}}" class="status-error">{{errorText}}</view>
  </view>

  <!-- 操作 -->
  <glass-card intensity="normal" padding="36rpx" customClass="mt-4">
    <view class="action-row">
      <gradient-button
        type="ghost"
        size="md"
        block="{{true}}"
        disabled="{{status === 'confirming'}}"
        bindtap="cancel"
      >
        <text>返回首页</text>
      </gradient-button>
      <gradient-button
        wx:if="{{status === 'failed'}}"
        type="primary"
        size="md"
        block="{{true}}"
        bindtap="retry"
      >
        <text>重试</text>
      </gradient-button>
    </view>

    <view class="mt-3 tip">扫码后自动确认登录，网页端将使用同一份算力点余额。</view>
  </glass-card>

  <glass-card intensity="subtle" padding="28rpx 32rpx" customClass="mt-3">
    <view class="tip">仅在你本人发起登录时扫码，如非本人操作请直接返回。</view>
  </glass-card>
</view>
