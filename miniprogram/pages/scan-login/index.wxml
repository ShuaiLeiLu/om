<view class="page animate-fade-in">
  <view class="page-header">
    <view class="section-title">客户端安全登录</view>
  </view>

  <!-- 状态区域 -->
  <view class="status-area">
    <view class="status-icon status-icon--{{status}}">
      <text wx:if="{{status === 'confirmed'}}">✓</text>
      <text wx:elif="{{status === 'failed'}}">×</text>
      <view wx:else class="spinner"></view>
    </view>
    <view class="status-text text-primary">{{statusText}}</view>
    <view wx:if="{{errorText}}" class="status-error">{{errorText}}</view>
  </view>

  <!-- 操作 -->
  <glass-card intensity="strong" padding="48rpx 40rpx" customClass="mt-4">
    <view class="action-row {{status === 'failed' ? 'action-row--double' : 'action-row--single'}}">
      <gradient-button
        type="ghost"
        size="md"
        block="{{true}}"
        disabled="{{status === 'confirming'}}"
        bindtap="cancel"
      >
        <text>返回首页</text>
      </gradient-button>
      <gradient-button
        wx:if="{{status === 'failed'}}"
        type="primary"
        size="md"
        block="{{true}}"
        bindtap="retry"
      >
        <text>重新登录</text>
      </gradient-button>
    </view>

    <view class="mt-4 tip text-tertiary">扫码确认后，客户端将同步关联此微信的算力点余额。</view>
  </glass-card>

  <glass-card intensity="subtle" padding="36rpx 40rpx" customClass="mt-4">
    <view class="tip text-tertiary">安全提示：仅在您本人操作客户端登录时进行扫码确认，防范账号盗用风险。</view>
  </glass-card>
</view>
