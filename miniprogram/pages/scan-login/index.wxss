.status-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 24rpx 20rpx;
  text-align: center;
}

.status-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 600;
  margin-bottom: 28rpx;
}

.status-icon--confirming,
.status-icon--ready {
  background: #f5f5f5;
  color: #999;
}

.status-icon--confirmed {
  background: #f0faf4;
  color: #1a9d5a;
}

.status-icon--failed {
  background: #fff0f0;
  color: #e54545;
}

.status-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  max-width: 520rpx;
}

.status-error {
  margin-top: 12rpx;
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  color: #e54545;
  background: #fff0f0;
  border-radius: 12rpx;
}

.action-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.tip {
  font-size: 22rpx;
  color: #999;
  text-align: center;
  line-height: 1.6;
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 4rpx solid #f0f0f0;
  border-top-color: #1a1a1a;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}
