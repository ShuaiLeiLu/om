.status-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 24rpx 40rpx;
  text-align: center;
}

.status-icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: 700;
  margin-bottom: 36rpx;
  border-width: 1rpx;
  border-style: solid;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

.status-icon--confirming,
.status-icon--ready {
  background: rgba(255, 255, 255, 0.03);
  border-color: rgba(255, 255, 255, 0.08);
  color: #6b7280;
}

.status-icon--confirmed {
  background: rgba(16, 185, 129, 0.08);
  border-color: rgba(16, 185, 129, 0.3);
  color: #34d399;
  box-shadow: 0 0 32rpx rgba(16, 185, 129, 0.2);
}

.status-icon--failed {
  background: rgba(239, 68, 68, 0.08);
  border-color: rgba(239, 68, 68, 0.3);
  color: #f87171;
  box-shadow: 0 0 32rpx rgba(239, 68, 68, 0.2);
}

.status-text {
  font-size: 32rpx;
  font-weight: 700;
  max-width: 520rpx;
}

.status-error {
  margin-top: 16rpx;
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  color: #f87171;
  background: rgba(239, 68, 68, 0.08);
  border: 1rpx solid rgba(239, 68, 68, 0.15);
  border-radius: 16rpx;
}

.action-row {
  display: grid;
  gap: 20rpx;
}

.action-row--double {
  grid-template-columns: 1fr 1fr;
}

.action-row--single {
  grid-template-columns: 1fr;
}

.tip {
  font-size: 22rpx;
  line-height: 1.6;
}

.spinner {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.1);
  border-left-color: #a855f7;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

