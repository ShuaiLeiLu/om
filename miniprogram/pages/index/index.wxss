.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 30rpx 30rpx 56rpx;
  background: #f5f6fa;
}

.hero {
  min-height: 420rpx;
  box-sizing: border-box;
  border-radius: 36rpx;
  padding: 36rpx;
  color: #fff;
  background: #10151f;
  box-shadow: 0 24rpx 60rpx rgba(16, 21, 31, 0.22);
}

.hero-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.brand {
  font-size: 42rpx;
  font-weight: 900;
}

.subtitle {
  color: rgba(255, 255, 255, 0.58);
  font-size: 22rpx;
  margin-top: 6rpx;
}

.status-pill {
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
  padding: 12rpx 22rpx;
}

.status-pill.ok {
  color: #10251f;
  background: #74f1c1;
}

.status-pill.wait {
  color: #fff;
  background: rgba(255, 255, 255, 0.16);
}

.balance-label {
  color: rgba(255, 255, 255, 0.58);
  font-size: 24rpx;
  margin-top: 72rpx;
}

.balance-value {
  font-size: 84rpx;
  font-weight: 900;
  line-height: 1.08;
  margin-top: 18rpx;
  word-break: break-all;
}

.balance-caption {
  color: rgba(255, 255, 255, 0.64);
  font-size: 24rpx;
  margin-top: 20rpx;
}

.panel {
  background: #fff;
  border: 1rpx solid #e8ebf0;
  border-radius: 30rpx;
  box-shadow: 0 14rpx 34rpx rgba(18, 25, 38, 0.06);
  margin-top: 28rpx;
  padding: 32rpx;
}

.state-panel {
  padding: 56rpx 34rpx;
  text-align: center;
}

.state-title {
  color: #10151f;
  font-size: 34rpx;
  font-weight: 900;
}

.state-desc {
  color: #737b8c;
  font-size: 26rpx;
  line-height: 1.6;
  margin-top: 14rpx;
}

.login-panel {
  border-color: #c7d2fe;
  background: #eef2ff;
}

.login-badge {
  display: inline-flex;
  align-items: center;
  border-radius: 999rpx;
  background: #dbe4ff;
  color: #3151b7;
  font-size: 22rpx;
  font-weight: 900;
  padding: 10rpx 18rpx;
}

.login-title {
  color: #10151f;
  font-size: 36rpx;
  font-weight: 900;
  margin-top: 24rpx;
}

.login-desc {
  color: #526077;
  font-size: 26rpx;
  line-height: 1.55;
  margin-top: 14rpx;
}

.login-status {
  background: #fff;
  border-radius: 18rpx;
  color: #0f766e;
  font-size: 24rpx;
  font-weight: 800;
  margin-top: 24rpx;
  padding: 18rpx 20rpx;
}

.login-actions {
  display: grid;
  grid-template-columns: 1fr 1.35fr;
  gap: 18rpx;
  margin-top: 30rpx;
}

.login-cancel,
.login-confirm {
  border-radius: 20rpx;
  font-size: 30rpx;
  font-weight: 900;
  height: 96rpx;
  line-height: 96rpx;
  margin: 0;
}

.login-cancel {
  background: #fff;
  color: #4b5565;
}

.login-confirm {
  background: #3151b7;
  color: #fff;
}

.login-confirm[disabled] {
  background: #aab7e8;
  color: #edf1ff;
}

.reward-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.section-label {
  color: #737b8c;
  font-size: 22rpx;
  font-weight: 700;
}

.reward-title {
  color: #10151f;
  font-size: 36rpx;
  font-weight: 900;
  margin-top: 8rpx;
}

.reward-amount {
  flex-shrink: 0;
  color: #0f766e;
  background: #e8fbf3;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 900;
  padding: 16rpx 20rpx;
}

.points-row {
  display: flex;
  justify-content: space-between;
  color: #737b8c;
  font-size: 24rpx;
  margin-top: 42rpx;
}

.progress {
  height: 14rpx;
  background: #eef1f5;
  border-radius: 999rpx;
  margin-top: 16rpx;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  background: #0f766e;
  border-radius: 999rpx;
}

.notice {
  color: #3f4a5d;
  background: #f6f8fb;
  border-radius: 18rpx;
  font-size: 24rpx;
  line-height: 1.5;
  margin-top: 28rpx;
  padding: 20rpx;
}

.claim-button {
  background: #0f766e;
  border-radius: 20rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 900;
  height: 108rpx;
  margin-top: 30rpx;
}

.claim-button[disabled] {
  background: #d6dce3;
  color: #8a93a1;
}

.secondary-button {
  background: #10151f;
  border-radius: 18rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: 800;
  margin-top: 32rpx;
}

.rules {
  margin-top: 28rpx;
  padding: 6rpx 8rpx;
}

.rule {
  display: flex;
  align-items: center;
  color: #737b8c;
  font-size: 24rpx;
  line-height: 1.7;
  padding: 10rpx 0;
}

.rule-mark {
  width: 10rpx;
  height: 10rpx;
  background: #0f766e;
  border-radius: 50%;
  flex-shrink: 0;
  margin-right: 14rpx;
}
