<view class="page">
  <view class="hero">
    <view class="hero-top">
      <view>
        <view class="brand">万模AI</view>
        <view class="subtitle">AI Token Center</view>
      </view>
      <view class="status-pill {{userInfo.bound ? 'ok' : 'wait'}}">
        {{userInfo.bound ? '已绑定' : '绑定中'}}
      </view>
    </view>

    <view class="balance-label">当前 Token</view>
    <view class="balance-value">{{balanceText}}</view>
    <view class="balance-caption">用于网页版多模型 AI 对话</view>
  </view>

  <view hidden="{{!loading}}" class="panel state-panel">
    <view class="state-title">正在同步</view>
    <view class="state-desc">读取微信身份与 Token 余额</view>
  </view>

  <view hidden="{{loading || !error}}" class="panel state-panel">
    <view class="state-title">读取失败</view>
    <view class="state-desc">{{error}}</view>
    <button class="secondary-button" bindtap="refreshData">重新加载</button>
  </view>

  <view hidden="{{loading || error}}">
    <view hidden="{{!loginPanelVisible}}" class="panel login-panel">
      <view class="login-badge">网页登录</view>
      <view class="login-title">确认登录万模AI网页端</view>
      <view class="login-desc">确认后，网页端会自动进入你的账号，并使用同一份 Token 余额。</view>
      <view hidden="{{!loginStatus}}" class="login-status">{{loginStatus}}</view>
      <view class="login-actions">
        <button class="login-cancel" bindtap="cancelWebLogin">取消</button>
        <button
          class="login-confirm"
          loading="{{loginConfirming}}"
          disabled="{{loginConfirming}}"
          bindtap="confirmWebLogin"
        >
          {{loginConfirming ? '确认中...' : '确认登录'}}
        </button>
      </view>
    </view>

    <view class="panel reward-panel">
      <view class="reward-top">
        <view>
          <view class="section-label">今日可领</view>
          <view class="reward-title">看广告获取 Token</view>
        </view>
        <view class="reward-amount">+{{rewardText}}</view>
      </view>

      <view class="quota-row">
        <text>剩余 {{remainingText}} 次</text>
        <text>上限 {{rewardConfig.dailyLimitPerUser || 0}} 次/天</text>
      </view>
      <view class="progress">
        <view class="progress-inner" style="width: {{progressPercent}}%;"></view>
      </view>

      <view class="notice">{{noticeText}}</view>

      <button
        class="claim-button"
        loading="{{claiming}}"
        disabled="{{claiming || actionDisabled}}"
        bindtap="watchAdAndClaim"
      >
        {{claiming ? '领取中...' : actionText}}
      </button>
    </view>

    <view class="rules">
      <view class="rule">
        <view class="rule-mark"></view>
        <text>完整观看广告才会发放 Token</text>
      </view>
      <view class="rule">
        <view class="rule-mark"></view>
        <text>中途关闭广告不会扣次数，也不会发放</text>
      </view>
      <view class="rule">
        <view class="rule-mark"></view>
        <text>余额和领取次数均以后端记录为准</text>
      </view>
    </view>
  </view>
</view>
