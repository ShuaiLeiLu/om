.content {
  padding: 100rpx 40rpx;
  text-align: center;
}

.icon-box {
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.desc {
  font-size: 28rpx;
  color: #8a8a8a;
  margin-bottom: 60rpx;
}

.info-card {
  background-color: #f9f9f9;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 60rpx;
  text-align: left;
}

.info-item {
  display: flex;
  margin-bottom: 20rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-item .label {
  width: 160rpx;
  color: #8a8a8a;
  font-size: 26rpx;
}

.info-item .value {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  word-break: break-all;
}

.actions {
  margin-bottom: 40rpx;
}

.error-tips {
  color: #ff4d4f;
  font-size: 26rpx;
  margin-bottom: 40rpx;
}

.footer {
  font-size: 24rpx;
  color: #ccc;
  line-height: 1.6;
}
