.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0 32rpx;
}

.brand {
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: -0.5rpx;
}

.state-title {
  font-size: 32rpx;
  font-weight: 700;
}

.state-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
}

.skeleton-line {
  height: 28rpx;
  width: 60%;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.05);
}

/* 作用说明区域 */
.info-banner {
  margin-top: 24rpx;
  margin-bottom: 24rpx;
  background: rgba(168, 85, 247, 0.02) !important;
  border-color: rgba(168, 85, 247, 0.12) !important;
  box-shadow: 0 12rpx 48rpx 0 rgba(0, 0, 0, 0.3), 
              0 0 32rpx 0 rgba(168, 85, 247, 0.05) !important;
}

.info-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.info-sparkle {
  font-size: 28rpx;
  text-shadow: 0 0 10rpx rgba(168, 85, 247, 0.6);
}

.info-title {
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}

.info-desc {
  font-size: 23rpx;
  line-height: 1.5;
  color: #9ca3af;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.info-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 12rpx;
}

.info-dot--purple {
  background: #a855f7;
  box-shadow: 0 0 8rpx #a855f7;
}

.info-dot--pink {
  background: #ec4899;
  box-shadow: 0 0 8rpx #ec4899;
}

.info-dot--blue {
  background: #6366f1;
  box-shadow: 0 0 8rpx #6366f1;
}

.info-text {
  font-size: 22rpx;
  color: #9ca3af;
  line-height: 1.4;
}

/* 重新设计的菜单 */
.menu-container {
  display: flex;
  flex-direction: column;
}

/* 主卡片：看广告领算力 */
.menu-main-card {
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.08) 0%, rgba(236, 72, 153, 0.08) 100%) !important;
  border-color: rgba(168, 85, 247, 0.25) !important;
  box-shadow: 0 12rpx 40rpx 0 rgba(0, 0, 0, 0.4), 
              0 0 24rpx 0 rgba(168, 85, 247, 0.1) !important;
}

.menu-main-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.menu-main-text {
  flex: 1;
  min-width: 0;
}

.menu-label-tag {
  font-size: 16rpx;
  font-weight: 700;
  color: #ec4899;
  letter-spacing: 2rpx;
  text-shadow: 0 0 8rpx rgba(236, 72, 153, 0.3);
  margin-bottom: 6rpx;
}

.menu-main-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 0.5rpx;
}

.menu-main-desc {
  font-size: 22rpx;
  color: #9ca3af;
}

.menu-main-action {
  flex-shrink: 0;
  margin-left: 24rpx;
}

.play-btn-circle {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #a855f7 0%, #ec4899 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 20rpx rgba(236, 72, 153, 0.4);
  transition: all 0.3s ease;
}

.play-triangle {
  width: 0;
  height: 0;
  border-style: solid;
  border-width: 10rpx 0 10rpx 18rpx;
  border-color: transparent transparent transparent #ffffff;
  margin-left: 6rpx;
}

/* 次级网格 */
.menu-sub-grid {
  display: flex;
  gap: 20rpx;
}

.menu-sub-card {
  height: 100%;
  display: flex;
  flex-direction: column;
  background: rgba(255, 255, 255, 0.05) !important;
  border-color: rgba(255, 255, 255, 0.12) !important;
  box-shadow: 0 8rpx 32rpx 0 rgba(0, 0, 0, 0.3) !important;
}

.menu-sub-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.menu-sub-icon--code {
  background: rgba(168, 85, 247, 0.1);
  border: 1rpx solid rgba(168, 85, 247, 0.2);
  box-shadow: 0 0 12rpx rgba(168, 85, 247, 0.1);
}

.menu-sub-icon--link {
  background: rgba(99, 102, 241, 0.1);
  border: 1rpx solid rgba(99, 102, 241, 0.2);
  box-shadow: 0 0 12rpx rgba(99, 102, 241, 0.1);
}

.menu-sub-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #ffffff;
}

.menu-sub-desc {
  font-size: 20rpx;
  color: #9ca3af;
  line-height: 1.3;
}

/* 图标细节绘制 */
.icon-code-dots {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6rpx;
}

.icon-dot-mini {
  width: 6rpx;
  height: 6rpx;
  border-radius: 50%;
  background: #a855f7;
  box-shadow: 0 0 4rpx #a855f7;
}

.icon-link-chain {
  display: flex;
  align-items: center;
  position: relative;
  width: 28rpx;
  height: 16rpx;
}

.icon-link-ring {
  width: 14rpx;
  height: 10rpx;
  border: 3rpx solid #6366f1;
  border-radius: 6rpx;
  box-shadow: 0 0 6rpx rgba(99, 102, 241, 0.3);
}

.icon-link-ring--second {
  position: absolute;
  right: 0;
  top: 4rpx;
  border-color: #ec4899;
  box-shadow: 0 0 6rpx rgba(236, 72, 153, 0.3);
}

.web-url {
  font-size: 24rpx;
  color: #a855f7;
  word-break: break-all;
  font-family: 'SF Mono', Menlo, Consolas, monospace;
  font-weight: 500;
  margin-top: 8rpx;
  letter-spacing: -0.2rpx;
}

