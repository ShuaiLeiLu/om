.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0 24rpx;
}

.brand {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: -1rpx;
}

.state-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.state-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.quick-item {
  position: relative;
}

.quick-label {
  font-size: 24rpx;
  color: #999;
}

.quick-value {
  margin-top: 12rpx;
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.quick-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #cccccc;
}

.web-url {
  font-size: 24rpx;
  color: #1a1a1a;
  word-break: break-all;
  font-family: 'SF Mono', Menlo, Consolas, monospace;
}
