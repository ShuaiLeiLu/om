<view class="page">
  <!-- 顶部品牌 -->
  <view class="header">
    <view class="brand">万模 AI</view>
    <status-pill tone="{{bound ? 'success' : 'warning'}}" text="{{bound ? '已绑定' : '绑定中'}}" />
  </view>

  <!-- 算力点余额卡 -->
  <token-balance
    balance="{{balanceText}}"
    label="算力点余额"
    caption="网页 / 小程序共享额度"
  />

  <!-- 错误态 -->
  <block wx:if="{{error && !loading}}">
    <glass-card customClass="mt-4" intensity="normal" padding="40rpx 36rpx">
      <view class="state-title">读取失败</view>
      <view class="state-desc">{{error}}</view>
      <view class="mt-3">
        <gradient-button type="primary" size="md" block="{{true}}" bindtap="refreshData">
          <text>重新加载</text>
        </gradient-button>
      </view>
    </glass-card>
  </block>

  <!-- 加载态 -->
  <block wx:elif="{{loading}}">
    <glass-card customClass="mt-4" intensity="subtle" padding="40rpx 36rpx">
      <view class="state-title text-secondary">正在同步...</view>
    </glass-card>
  </block>

  <!-- 正常态 -->
  <block wx:else>
    <!-- 快捷入口 -->
    <view class="mt-4 quick-grid">
      <glass-card intensity="normal" padding="32rpx" customClass="quick-item" bind:tap="goRewards">
        <view class="quick-label">看广告领取</view>
        <view class="quick-value">+{{rewardText}}</view>
        <view class="quick-meta">剩余 {{remainingText}} 次</view>
      </glass-card>

      <glass-card intensity="normal" padding="32rpx" customClass="quick-item" bind:tap="goProfile">
        <view class="quick-label">{{emailLinked ? '邮箱已绑定' : '绑定邮箱'}}</view>
        <view class="quick-value">{{emailLinked ? '✓' : '→'}}</view>
        <view class="quick-meta">个人中心</view>
      </glass-card>
    </view>

    <!-- 网页提示 -->
    <glass-card intensity="subtle" padding="28rpx 32rpx" customClass="mt-3">
      <view class="row-between">
        <view class="flex-1">
          <view class="text-sm text-secondary">网页工作台</view>
          <view class="mt-1 web-url">{{webUrl}}</view>
        </view>
        <gradient-button type="ghost" size="sm" bindtap="copyWebUrl">
          <text>复制</text>
        </gradient-button>
      </view>
    </glass-card>
  </block>
</view>
