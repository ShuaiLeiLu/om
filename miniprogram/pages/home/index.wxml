<view class="page">
  <view class="page-header">
    <view class="uppercase-label">My Wallet</view>
    <view class="row-between gap-2">
      <view class="brand text-2xl font-bold">
        <text class="text-gradient">万模 AI</text>
      </view>
      <status-pill tone="{{bound ? 'success' : 'warning'}}" text="{{bound ? '已绑定微信' : '绑定中'}}" />
    </view>
  </view>

  <!-- Token 余额卡 -->
  <token-balance
    balance="{{balanceText}}"
    label="Token 余额"
    caption="网页 / 小程序共享额度"
  />

  <!-- 错误态 -->
  <block wx:if="{{error && !loading}}">
    <glass-card customClass="gap-4" intensity="normal">
      <view class="state-title">读取失败</view>
      <view class="state-desc">{{error}}</view>
      <view class="gap-3">
        <gradient-button type="primary" size="md" block="{{true}}" bindtap="refreshData">
          <text>重新加载</text>
        </gradient-button>
      </view>
    </glass-card>
  </block>

  <!-- 加载态 -->
  <block wx:elif="{{loading}}">
    <glass-card customClass="gap-4" intensity="subtle">
      <view class="state-title muted">正在同步</view>
      <view class="state-desc muted">读取微信身份与 Token 余额</view>
    </glass-card>
  </block>

  <!-- 正常态 -->
  <block wx:else>
    <!-- 快捷入口 -->
    <view class="gap-4 quick-grid">
      <glass-card intensity="normal" padding="32rpx" customClass="quick-item" bind:tap="goAi">
        <view class="quick-icon quick-icon--cyan">AI</view>
        <view class="quick-title">AI 创作</view>
        <view class="quick-sub">文字对话 / 文生图</view>
        <view class="quick-meta muted">小程序端直连</view>
      </glass-card>

      <glass-card intensity="normal" padding="32rpx" customClass="quick-item" bind:tap="goRewards">
        <view class="quick-icon quick-icon--amber">⚡</view>
        <view class="quick-title">看广告</view>
        <view class="quick-sub">领 +{{rewardText}}</view>
        <view class="quick-meta muted">剩余 {{remainingText}} 次</view>
      </glass-card>

      <glass-card intensity="normal" padding="32rpx" customClass="quick-item quick-item--wide" bind:tap="goProfile">
        <view class="quick-icon quick-icon--indigo">{{emailLinked ? '✓' : '＋'}}</view>
        <view class="quick-title">{{emailLinked ? '邮箱已绑定' : '绑定邮箱'}}</view>
        <view class="quick-sub">{{emailLinked ? '可在网页用邮箱登录' : '让网页 / 小程序互通'}}</view>
        <view class="quick-meta muted">个人中心</view>
      </glass-card>
    </view>

    <!-- 网页提示 -->
    <glass-card intensity="subtle" padding="28rpx 32rpx" customClass="gap-4 web-card">
      <view class="row-between">
        <view class="flex-1">
          <view class="text-sm muted">网页对话与图片工作台</view>
          <view class="gap-1 web-url">{{webUrl}}</view>
        </view>
        <gradient-button type="ghost" size="sm" bindtap="copyWebUrl">
          <text>复制</text>
        </gradient-button>
      </view>
    </glass-card>
  </block>
</view>
