<view class="page animate-fade-in">
  <view class="page-header">
    <view class="section-title">客户端登录码</view>
    <view class="section-desc text-secondary">在客户端输入此验证码即可登录同一账号</view>
  </view>

  <!-- 登录码显示 -->
  <glass-card intensity="strong" padding="64rpx 40rpx" customClass="code-card">
    <block wx:if="{{loading}}">
      <view class="code-loading">
        <view class="spinner"></view>
      </view>
    </block>
    <block wx:elif="{{code}}">
      <view class="code-digits animate-fade-in">
        <view class="code-digit-wrapper" wx:for="{{code}}" wx:key="index">
          <text class="code-digit">{{item}}</text>
        </view>
      </view>
    </block>
    <block wx:else>
      <view class="code-empty">- - - - - -</view>
    </block>

    <!-- 倒计时 -->
    <view wx:if="{{code && countdown > 0}}" class="timer">
      <view class="timer-bar">
        <view class="timer-fill" style="width: {{countdown / 120 * 100}}%"></view>
      </view>
      <view class="timer-text text-secondary">{{countdown}} 秒后失效</view>
    </view>

    <!-- 错误提示 -->
    <view wx:if="{{error}}" class="code-error">{{error}}</view>
  </glass-card>

  <!-- 操作 -->
  <view class="mt-4">
    <gradient-button
      type="primary"
      size="md"
      block="{{true}}"
      loading="{{loading}}"
      bindtap="refresh"
    >
      <text>{{code ? '刷新登录码' : '生成登录码'}}</text>
    </gradient-button>
  </view>

  <view class="mt-3 tip text-tertiary">登录码 2 分钟内有效，仅限使用一次。</view>

  <!-- 使用说明 -->
  <glass-card intensity="subtle" padding="36rpx 40rpx" customClass="mt-4">
    <view class="help-title text-primary font-bold">使用方法</view>
    <view class="help-steps mt-3">
      <view class="help-step">
        <view class="step-num-container">
          <text class="step-num">1</text>
        </view>
        <view class="step-text text-secondary">在电脑上打开客户端登录页</view>
      </view>
      <view class="help-step">
        <view class="step-num-container">
          <text class="step-num">2</text>
        </view>
        <view class="step-text text-secondary">选择「验证码登录」方式</view>
      </view>
      <view class="help-step">
        <view class="step-num-container">
          <text class="step-num">3</text>
        </view>
        <view class="step-text text-secondary">在客户端输入上方 6 位数字验证码</view>
      </view>
    </view>
  </glass-card>
</view>
