<view class="page">
  <view class="page-header">
    <view class="section-title">网页登录码</view>
    <view class="section-desc">在网页端输入以下 6 位数字即可登录</view>
  </view>

  <!-- 登录码显示 -->
  <glass-card intensity="normal" padding="48rpx 36rpx" customClass="code-card">
    <block wx:if="{{loading}}">
      <view class="code-loading">
        <view class="spinner"></view>
      </view>
    </block>
    <block wx:elif="{{code}}">
      <view class="code-digits">
        <text class="code-digit" wx:for="{{code}}" wx:key="index">{{item}}</text>
      </view>
    </block>
    <block wx:else>
      <view class="code-empty">- - - - - -</view>
    </block>

    <!-- 倒计时 -->
    <view wx:if="{{code && countdown > 0}}" class="timer">
      <view class="timer-bar">
        <view class="timer-fill" style="width: {{countdown / 120 * 100}}%"></view>
      </view>
      <view class="timer-text">{{countdown}} 秒后过期</view>
    </view>

    <!-- 错误提示 -->
    <view wx:if="{{error}}" class="code-error">{{error}}</view>
  </glass-card>

  <!-- 操作 -->
  <view class="mt-3">
    <gradient-button
      type="primary"
      size="md"
      block="{{true}}"
      loading="{{loading}}"
      bindtap="refresh"
    >
      <text>{{code ? '刷新登录码' : '生成登录码'}}</text>
    </gradient-button>
  </view>

  <view class="mt-2 tip">登录码 2 分钟内有效，仅可使用一次。</view>

  <!-- 使用说明 -->
  <glass-card intensity="subtle" padding="28rpx 32rpx" customClass="mt-4">
    <view class="help-title">使用方法</view>
    <view class="help-steps">
      <view class="help-step">
        <view class="step-num">1</view>
        <view class="step-text">打开网页端登录页面</view>
      </view>
      <view class="help-step">
        <view class="step-num">2</view>
        <view class="step-text">选择「登录码」方式</view>
      </view>
      <view class="help-step">
        <view class="step-num">3</view>
        <view class="step-text">输入上方 6 位数字</view>
      </view>
    </view>
  </glass-card>
</view>
