.code-card {
  text-align: center;
}

.code-digits {
  display: flex;
  gap: 16rpx;
  justify-content: center;
  margin: 32rpx 0;
}

.code-digit-wrapper {
  width: 80rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.04);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  box-shadow: 0 8rpx 32rpx 0 rgba(0, 0, 0, 0.2), 
              inset 0 0 0 1rpx rgba(255, 255, 255, 0.05),
              0 0 16rpx rgba(168, 85, 247, 0.15);
  font-variant-numeric: tabular-nums;
  backdrop-filter: blur(10px);
  transition: all 0.3s ease;
}

.code-digit {
  font-size: 52rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 0 8rpx rgba(255, 255, 255, 0.3);
}

.code-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100rpx;
}

.code-empty {
  font-size: 40rpx;
  color: #6b7280;
  letter-spacing: 12rpx;
  font-weight: 600;
  height: 100rpx;
  line-height: 100rpx;
  text-shadow: 0 0 8rpx rgba(255, 255, 255, 0.1);
}

.timer {
  margin-top: 36rpx;
}

.timer-bar {
  height: 6rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 3rpx;
  overflow: hidden;
}

.timer-fill {
  height: 100%;
  background: linear-gradient(90deg, #6366f1, #a855f7, #ec4899);
  border-radius: 3rpx;
  transition: width 1s linear;
  box-shadow: 0 0 8rpx rgba(168, 85, 247, 0.5);
}

.timer-text {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #9ca3af;
  font-variant-numeric: tabular-nums;
}

.code-error {
  margin-top: 24rpx;
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  color: #f87171;
  background: rgba(239, 68, 68, 0.1);
  border: 1rpx solid rgba(239, 68, 68, 0.2);
  border-radius: 12rpx;
  backdrop-filter: blur(10px);
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.1);
  border-left-color: #a855f7;
  animation: spin 0.8s linear infinite;
  box-shadow: 0 0 16rpx rgba(168, 85, 247, 0.2);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.tip {
  font-size: 24rpx;
  color: #6b7280;
  text-align: center;
}

.help-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 24rpx;
}

.help-steps {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.help-step {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.step-num-container {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.2) 0%, rgba(168, 85, 247, 0.2) 100%);
  border: 1rpx solid rgba(168, 85, 247, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 0 8rpx rgba(168, 85, 247, 0.1);
}

.step-num {
  font-size: 22rpx;
  font-weight: 600;
  color: #a855f7;
}

.step-text {
  font-size: 26rpx;
  color: #9ca3af;
}
