.code-card {
  text-align: center;
}

.code-digits {
  display: flex;
  gap: 16rpx;
  justify-content: center;
}

.code-digit {
  width: 80rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a1a;
  background: #f5f5f5;
  border-radius: 16rpx;
  font-variant-numeric: tabular-nums;
}

.code-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100rpx;
}

.code-empty {
  font-size: 40rpx;
  color: #ccc;
  letter-spacing: 8rpx;
  font-weight: 600;
  height: 100rpx;
  line-height: 100rpx;
}

.timer {
  margin-top: 28rpx;
}

.timer-bar {
  height: 4rpx;
  background: #f0f0f0;
  border-radius: 2rpx;
  overflow: hidden;
}

.timer-fill {
  height: 100%;
  background: #1a1a1a;
  border-radius: 2rpx;
  transition: width 1s linear;
}

.timer-text {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #999;
  font-variant-numeric: tabular-nums;
}

.code-error {
  margin-top: 20rpx;
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  color: #e54545;
  background: #fff0f0;
  border-radius: 12rpx;
}

.spinner {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 4rpx solid #f0f0f0;
  border-top-color: #1a1a1a;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.tip {
  font-size: 22rpx;
  color: #999;
  text-align: center;
}

.help-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #666;
  margin-bottom: 16rpx;
}

.help-steps {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.help-step {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.step-num {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  color: #999;
  flex-shrink: 0;
}

.step-text {
  font-size: 24rpx;
  color: #666;
}
