.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.flex-1 { flex: 1; min-width: 0; }

.state-title {
  font-size: 32rpx;
  font-weight: 600;
}

.state-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.reward-amount {
  margin-top: 12rpx;
  font-size: 88rpx;
  font-weight: 700;
  line-height: 1.05;
  letter-spacing: -2rpx;
  background: linear-gradient(135deg, #10b981, #34d399, #6ee7b7);
  -webkit-background-clip: text;
  color: transparent;
}

.reward-amount-sub {
  margin-top: 4rpx;
  font-size: 22rpx;
}

.reward-emoji {
  font-size: 88rpx;
  line-height: 1;
  filter: drop-shadow(0 8rpx 24rpx rgba(245, 158, 11, 0.4));
}

.quota-row {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #94a3b8;
}

.progress {
  margin-top: 12rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.06);
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #10b981, #14b8a6, #06b6d4);
  transition: width 0.3s ease;
}

.notice {
  font-size: 22rpx;
}

.rules {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #cbd5e1;
}

.rule {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.rule-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6366f1, #a855f7);
  margin-top: 14rpx;
  flex-shrink: 0;
}
