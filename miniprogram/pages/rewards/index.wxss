.state-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.state-desc {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999;
}

.reward-label {
  font-size: 24rpx;
  color: #999;
}

.reward-amount {
  margin-top: 8rpx;
  font-size: 72rpx;
  font-weight: 700;
  line-height: 1.1;
  color: #1a1a1a;
  letter-spacing: -2rpx;
}

.reward-unit {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #cccccc;
}

.quota-row {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #999;
}

.progress {
  margin-top: 12rpx;
  height: 8rpx;
  border-radius: 4rpx;
  background: #f0f0f0;
  overflow: hidden;
}

.progress-inner {
  height: 100%;
  border-radius: 4rpx;
  background: #1a1a1a;
  transition: width 0.3s ease;
}

.notice {
  font-size: 22rpx;
  color: #999;
}

.rule-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #666;
  margin-bottom: 16rpx;
}

.rules {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rule {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}
