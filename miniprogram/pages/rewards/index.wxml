<view class="page">
  <view class="page-header">
    <view class="section-title">看广告领算力点</view>
  </view>

  <token-balance
    balance="{{balanceText}}"
    label="当前算力点"
    caption="完整观看广告后自动到账"
  />

  <block wx:if="{{error && !loading}}">
    <glass-card customClass="mt-4" intensity="normal" padding="40rpx 36rpx">
      <view class="state-title">读取失败</view>
      <view class="state-desc">{{error}}</view>
      <view class="mt-3">
        <gradient-button type="primary" size="md" block="{{true}}" bindtap="refreshData">
          <text>重新加载</text>
        </gradient-button>
      </view>
    </glass-card>
  </block>

  <block wx:elif="{{loading}}">
    <glass-card customClass="mt-4" intensity="subtle" padding="40rpx 36rpx">
      <view class="state-title text-secondary">正在同步奖励信息...</view>
    </glass-card>
  </block>

  <block wx:else>
    <!-- 主奖励卡 -->
    <glass-card customClass="mt-4" intensity="normal" padding="40rpx 36rpx">
      <view class="reward-label">今日可领</view>
      <view class="reward-amount">+{{rewardText}}</view>
      <view class="reward-unit">算力点 / 次</view>

      <view class="mt-3 quota-row">
        <text>剩余 {{remainingText}} 次</text>
        <text>上限 {{limitText}} 次 / 天</text>
      </view>
      <view class="progress">
        <view class="progress-inner" style="width: {{progressPercent}}%;"></view>
      </view>

      <view class="mt-3 notice">{{noticeText}}</view>

      <view class="mt-4">
        <gradient-button
          type="primary"
          size="lg"
          block="{{true}}"
          loading="{{claiming}}"
          disabled="{{actionDisabled}}"
          bindtap="watchAdAndClaim"
        >
          <text>{{claiming ? '领取中...' : actionText}}</text>
        </gradient-button>
      </view>
    </glass-card>

    <!-- 规则说明 -->
    <glass-card customClass="mt-3" intensity="subtle" padding="28rpx 32rpx">
      <view class="rule-title">规则说明</view>
      <view class="rules">
        <view class="rule">· 完整观看广告才会发放算力点</view>
        <view class="rule">· 中途关闭广告不会扣次数，也不会发放</view>
        <view class="rule">· 余额和领取次数均以后端记录为准</view>
      </view>
    </glass-card>
  </block>
</view>
