<view class="page">
  <view class="page-header">
    <view class="uppercase-label">Reward Center</view>
    <view class="text-2xl font-bold">
      <text>看广告领 </text>
      <text class="text-gradient">Token</text>
    </view>
  </view>

  <token-balance
    balance="{{balanceText}}"
    label="当前 Token"
    caption="完整观看广告后自动到账"
  />

  <block wx:if="{{error && !loading}}">
    <glass-card customClass="gap-4">
      <view class="state-title">读取失败</view>
      <view class="state-desc">{{error}}</view>
      <view class="gap-3">
        <gradient-button type="primary" size="md" block="{{true}}" bindtap="refreshData">
          <text>重新加载</text>
        </gradient-button>
      </view>
    </glass-card>
  </block>

  <block wx:elif="{{loading}}">
    <glass-card customClass="gap-4" intensity="subtle">
      <view class="state-title muted">正在同步奖励信息...</view>
    </glass-card>
  </block>

  <block wx:else>
    <!-- 主奖励卡 -->
    <glass-card customClass="gap-4 reward-card" intensity="normal" padding="40rpx 36rpx">
      <view class="row-between">
        <view class="flex-1">
          <view class="uppercase-label">今日可领</view>
          <view class="reward-amount">+{{rewardText}}</view>
          <view class="reward-amount-sub muted">Token / 次</view>
        </view>
        <view class="reward-emoji">🎁</view>
      </view>

      <view class="gap-4 quota-row">
        <text>剩余 {{remainingText}} 次</text>
        <text>上限 {{limitText}} 次 / 天</text>
      </view>
      <view class="progress">
        <view class="progress-inner" style="width: {{progressPercent}}%;"></view>
      </view>

      <view class="gap-3 notice muted-light">{{noticeText}}</view>

      <view class="gap-4">
        <gradient-button
          type="emerald"
          size="lg"
          block="{{true}}"
          icon="▶"
          loading="{{claiming}}"
          disabled="{{actionDisabled}}"
          bindtap="watchAdAndClaim"
        >
          <text>{{claiming ? '领取中...' : actionText}}</text>
        </gradient-button>
      </view>
    </glass-card>

    <!-- 规则说明 -->
    <glass-card customClass="gap-4" intensity="subtle" padding="28rpx 32rpx">
      <view class="uppercase-label">规则说明</view>
      <view class="rules gap-2">
        <view class="rule">
          <view class="rule-dot"></view>
          <text>完整观看广告才会发放 Token</text>
        </view>
        <view class="rule">
          <view class="rule-dot"></view>
          <text>中途关闭广告不会扣次数，也不会发放</text>
        </view>
        <view class="rule">
          <view class="rule-dot"></view>
          <text>余额和领取次数均以后端记录为准</text>
        </view>
      </view>
    </glass-card>
  </block>
</view>
