<view class="page animate-fade-in">
  <view class="page-header">
    <view class="section-title">看广告领算力点</view>
  </view>

  <token-balance
    balance="{{balanceText}}"
    label="当前算力点"
    caption="完整观看广告后自动到账"
  />

  <block wx:if="{{error && !loading}}">
    <glass-card customClass="mt-4" intensity="strong" padding="48rpx 40rpx">
      <view class="state-title text-primary">读取失败</view>
      <view class="state-desc text-secondary">{{error}}</view>
      <view class="mt-4">
        <gradient-button type="primary" size="md" block="{{true}}" bindtap="refreshData">
          <text>重新加载</text>
        </gradient-button>
      </view>
    </glass-card>
  </block>

  <block wx:elif="{{loading}}">
    <glass-card customClass="mt-4 skeleton" intensity="subtle" padding="48rpx 40rpx">
      <view class="state-title text-secondary">正在同步奖励信息...</view>
      <view class="skeleton-line mt-2"></view>
    </glass-card>
  </block>

  <block wx:else>
    <!-- 主奖励卡 -->
    <glass-card customClass="mt-4" intensity="strong" padding="48rpx 40rpx">
      <view class="reward-label">今日单次可领</view>
      <view class="reward-amount">+{{rewardText}}</view>
      <view class="reward-unit">算力点 / 每次</view>

      <view class="mt-4 quota-row text-secondary">
        <text class="font-medium">今日剩余 {{remainingText}} 次</text>
        <text class="text-tertiary">日上限 {{limitText}} 次</text>
      </view>
      <view class="progress">
        <view class="progress-inner" style="width: {{progressPercent}}%;"></view>
      </view>

      <view class="mt-4 notice text-tertiary">{{noticeText}}</view>

      <view class="mt-4">
        <gradient-button
          type="primary"
          size="lg"
          block="{{true}}"
          loading="{{claiming}}"
          disabled="{{actionDisabled}}"
          bindtap="watchAdAndClaim"
        >
          <text>{{claiming ? '领取中...' : actionText}}</text>
        </gradient-button>
      </view>
    </glass-card>

    <!-- 规则说明 -->
    <glass-card customClass="mt-4" intensity="subtle" padding="36rpx 40rpx">
      <view class="rule-title">活动规则</view>
      <view class="rules">
        <view class="rule">
          <view class="rule-dot"></view>
          <text class="rule-text">完整观看视频广告，才会发放对应的算力点</text>
        </view>
        <view class="rule">
          <view class="rule-dot"></view>
          <text class="rule-text">中途关闭广告不会扣除今日额度，也无法获得奖励</text>
        </view>
        <view class="rule">
          <view class="rule-dot"></view>
          <text class="rule-text">算力点余额和小程序领奖次数均以后端服务器记录为准</text>
        </view>
      </view>
    </glass-card>
  </block>
</view>
