<view class="page animate-fade-in">
  <!-- 用户卡 -->
  <glass-card intensity="strong" glow="{{true}}" padding="40rpx" customClass="user-card">
    <view class="user-row">
      <view class="avatar-container">
        <view class="avatar-glow-ring"></view>
        <view class="avatar">
          <image wx:if="{{userInfo.avatarUrl}}" class="avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
          <view wx:else class="avatar-fallback">{{avatarInitial}}</view>
        </view>
      </view>
      <view class="user-meta">
        <view class="user-name text-primary">{{userInfo.displayName || '微信用户'}}</view>
        <view class="user-balance mt-1">
          <text class="user-balance-num text-gradient">{{balanceText}}</text>
          <text class="text-secondary font-medium"> 算力点</text>
        </view>
      </view>
      <status-pill
        tone="{{userInfo.bound ? 'success' : 'warning'}}"
        text="{{userInfo.bound ? '已绑定' : '绑定中'}}"
      />
    </view>
  </glass-card>

  <!-- 邮箱绑定卡 -->
  <glass-card intensity="normal" padding="40rpx" customClass="mt-4">
    <view class="row-between">
      <view class="flex-1">
        <view class="text-tertiary text-xs font-semibold">客户端账号</view>
        <view class="mt-2 text-primary font-bold text-lg">
          {{userInfo.email ? '已关联独立邮箱' : '尚未关联邮箱'}}
        </view>
        <view class="mt-2 text-sm text-secondary">
          {{userInfo.email ? emailMasked : '绑定邮箱后，可在客户端使用邮箱+密码直接登录'}}
        </view>
      </view>
    </view>

    <view class="mt-4">
      <block wx:if="{{userInfo.email}}">
        <gradient-button type="danger" size="md" block="{{true}}" bindtap="openUnbindSheet">
          <text>解除邮箱绑定</text>
        </gradient-button>
      </block>
      <block wx:else>
        <gradient-button type="primary" size="md" block="{{true}}" bindtap="openBindSheet">
          <text>立即绑定邮箱</text>
        </gradient-button>
      </block>
    </view>
  </glass-card>

  <!-- 功能列表 -->
  <glass-card intensity="normal" padding="0" customClass="mt-4 list-card">
    <view class="list-item" bindtap="openWebLoginCode">
      <view class="list-text">
        <view class="list-title">客户端登录码</view>
        <view class="list-sub">生成 6 位临时验证码，在客户端快速扫码/输入登录</view>
      </view>
      <view class="list-arrow">›</view>
    </view>
    <view class="divider"></view>
    <view class="list-item" bindtap="logout">
      <view class="list-text">
        <view class="list-title list-title--danger">退出当前账号</view>
        <view class="list-sub">清除本地缓存的微信会话状态并重新登录</view>
      </view>
      <view class="list-arrow">›</view>
    </view>
  </glass-card>

  <view class="legal text-tertiary">
    继续使用即表示您已阅读并同意《服务协议》与《隐私条款》
  </view>
</view>

<!-- 邮箱绑定 / 解绑 Bottom Sheet -->
<view wx:if="{{sheetVisible}}" class="sheet-mask" bindtap="closeSheet" catchtouchmove="noop">
  <view class="sheet" catchtap="noop">
    <view class="sheet-handle"></view>
 
    <block wx:if="{{sheetMode === 'bind'}}">
      <view class="sheet-title text-primary">绑定客户端登录邮箱</view>
      <view class="sheet-sub text-secondary">绑定邮箱后，可在客户端使用该邮箱与密码直接登录。</view>
 
      <view class="form-field">
        <view class="form-label text-tertiary">邮箱地址</view>
        <input
          class="form-input"
          type="text"
          confirm-type="next"
          placeholder="请输入常用邮箱地址"
          placeholder-class="form-placeholder"
          value="{{bindEmail}}"
          bindinput="onEmailInput"
        />
      </view>
 
      <view class="form-field">
        <view class="form-label text-tertiary">设置登录密码</view>
        <input
          class="form-input"
          type="text"
          password="{{true}}"
          confirm-type="next"
          placeholder="长度不少于 8 位，须含字母和数字"
          placeholder-class="form-placeholder"
          value="{{bindPassword}}"
          bindinput="onPasswordInput"
        />
      </view>
 
      <view class="form-field">
        <view class="form-label text-tertiary">邮箱验证码</view>
        <view class="form-code-row">
          <input
            class="form-input form-input--code"
            type="number"
            confirm-type="done"
            placeholder="6位验证码"
            placeholder-class="form-placeholder"
            value="{{bindCode}}"
            maxlength="6"
            bindinput="onCodeInput"
          />
          <button
            class="form-code-btn {{codeCooldown > 0 || sendingCode || !bindEmail ? 'form-code-btn--disabled' : ''}}"
            disabled="{{codeCooldown > 0 || sendingCode || !bindEmail}}"
            bindtap="sendBindCode"
          >
            {{sendingCode ? '发送中...' : codeCooldown > 0 ? codeCooldown + 's' : '发送验证码'}}
          </button>
        </view>
      </view>
 
      <view wx:if="{{bindError}}" class="form-error">{{bindError}}</view>
 
      <view class="sheet-actions">
        <gradient-button type="ghost" size="md" block="{{true}}" bindtap="closeSheet">
          <text>取消</text>
        </gradient-button>
        <gradient-button
          type="primary"
          size="md"
          block="{{true}}"
          loading="{{sheetSubmitting}}"
          bindtap="submitBind"
        >
          <text>{{sheetSubmitting ? '绑定中...' : '确定绑定'}}</text>
        </gradient-button>
      </view>
    </block>
 
    <block wx:else>
      <view class="sheet-title text-primary">解除邮箱绑定</view>
      <view class="sheet-sub text-secondary">
        确认要解除与 {{emailMasked}} 的绑定吗？解绑后，客户端将无法使用此邮箱登录当前算力账户。
      </view>
      <view class="sheet-actions">
        <gradient-button type="ghost" size="md" block="{{true}}" bindtap="closeSheet">
          <text>点错了</text>
        </gradient-button>
        <gradient-button
          type="danger"
          size="md"
          block="{{true}}"
          loading="{{sheetSubmitting}}"
          bindtap="submitUnbind"
        >
          <text>{{sheetSubmitting ? '解绑中...' : '确认解绑'}}</text>
        </gradient-button>
      </view>
    </block>
  </view>
</view>
