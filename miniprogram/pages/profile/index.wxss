.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.flex-1 { flex: 1; min-width: 0; }

/* 用户卡 */
.user-card .user-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  overflow: hidden;
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  background: linear-gradient(135deg, #6366f1, #a855f7);
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  color: #ffffff;
  font-weight: 700;
}

.user-meta {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #f1f5f9;
}

.user-balance {
  margin-top: 6rpx;
  font-size: 24rpx;
}

.user-balance-num {
  color: #c4b5fd;
  font-weight: 600;
  margin-right: 6rpx;
}

/* 邮箱卡 */
.email-card .email-title {
  margin-top: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #f1f5f9;
}

.email-card .email-sub {
  margin-top: 6rpx;
  font-size: 24rpx;
}

.email-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.25), rgba(168, 85, 247, 0.15));
  border: 2rpx solid rgba(99, 102, 241, 0.3);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
}

/* 列表卡 */
.list-card {
  padding: 0 !important;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 28rpx 36rpx;
  gap: 20rpx;
}

.list-item:active {
  background: rgba(255, 255, 255, 0.03);
}

.list-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.06);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  flex-shrink: 0;
}

.list-icon--danger {
  background: rgba(244, 63, 94, 0.12);
  color: #fda4af;
}

.list-text { flex: 1; min-width: 0; }

.list-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #f1f5f9;
}

.list-title--danger {
  color: #fda4af;
}

.list-sub {
  font-size: 22rpx;
  margin-top: 4rpx;
}

.list-arrow {
  font-size: 36rpx;
  color: #475569;
}

.divider {
  height: 2rpx;
  background: rgba(255, 255, 255, 0.05);
  margin: 0 36rpx;
}

.legal {
  margin-top: 40rpx;
  font-size: 20rpx;
  text-align: center;
}

/* —— sheet —— */
.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.7);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.sheet {
  width: 100%;
  background: rgba(15, 17, 32, 0.97);
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  border-top: 2rpx solid rgba(255, 255, 255, 0.08);
  padding: 24rpx 40rpx calc(40rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -16rpx 64rpx rgba(0, 0, 0, 0.5);
}

.sheet-handle {
  width: 80rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 999rpx;
  margin: 0 auto 24rpx;
}

.sheet-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #f1f5f9;
}

.sheet-sub {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
}

.form-field {
  margin-top: 24rpx;
}

.form-label {
  font-size: 22rpx;
  color: #94a3b8;
  margin-bottom: 10rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  box-sizing: border-box;
  padding: 0 28rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.04);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  color: #ffffff;
  font-size: 28rpx;
}

.form-placeholder { color: #64748b; }

.form-code-row {
  display: flex;
  gap: 16rpx;
  align-items: stretch;
}

.form-input--code {
  flex: 1;
  font-family: 'SF Mono', Menlo, Consolas, monospace;
  letter-spacing: 12rpx;
}

.form-code-btn {
  flex-shrink: 0;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.3), rgba(168, 85, 247, 0.2));
  border: 2rpx solid rgba(99, 102, 241, 0.4);
  color: #c7d2fe;
  font-size: 22rpx;
  font-weight: 500;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.form-code-btn:active {
  transform: scale(0.97);
  filter: brightness(1.1);
}

.form-code-btn--disabled {
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(255, 255, 255, 0.08);
  color: #64748b;
  opacity: 0.7;
}

.form-error {
  margin-top: 18rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  background: rgba(244, 63, 94, 0.12);
  border: 2rpx solid rgba(244, 63, 94, 0.3);
  color: #fda4af;
  font-size: 22rpx;
}

.sheet-actions {
  margin-top: 32rpx;
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 20rpx;
}
