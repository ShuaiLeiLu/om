/* 用户卡 */
.user-card .user-row {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.avatar-container {
  position: relative;
  width: 104rpx;
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-glow-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  padding: 4rpx;
  background: linear-gradient(135deg, #6366f1, #a855f7, #ec4899);
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  pointer-events: none;
  opacity: 0.85;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.05);
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  color: #a855f7;
  font-weight: 700;
  background: rgba(168, 85, 247, 0.1);
}

.user-meta {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}

.user-balance {
  font-size: 24rpx;
}

.user-balance-num {
  font-size: 40rpx;
  font-weight: 800;
  margin-right: 6rpx;
}

/* 列表卡 */
.list-card {
  padding: 0 !important;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 32rpx 40rpx;
  gap: 20rpx;
  transition: background-color 0.2s ease;
}

.list-item:active {
  background: rgba(255, 255, 255, 0.02);
}

.list-text { flex: 1; min-width: 0; }

.list-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

.list-title--danger {
  color: #f87171;
  text-shadow: 0 0 12rpx rgba(248, 113, 113, 0.1);
}

.list-sub {
  font-size: 22rpx;
  color: #9ca3af;
  margin-top: 8rpx;
}

.list-arrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.15);
  font-weight: 300;
}

.legal {
  margin-top: 48rpx;
  font-size: 20rpx;
  text-align: center;
  line-height: 1.5;
}

/* —— Bottom Sheet —— */
.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(2, 4, 10, 0.6);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.sheet {
  width: 100%;
  background: #080b1e;
  border-top-left-radius: 36rpx;
  border-top-right-radius: 36rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.08);
  padding: 24rpx 40rpx calc(48rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -12rpx 40rpx rgba(0, 0, 0, 0.5);
  box-sizing: border-box;
}

.sheet-handle {
  width: 72rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 4rpx;
  margin: 0 auto 32rpx;
}

.sheet-title {
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}

.sheet-sub {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
}

.form-field {
  margin-top: 32rpx;
}

.form-label {
  font-size: 22rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
  text-transform: uppercase;
}

.form-input {
  width: 100%;
  height: 96rpx;
  box-sizing: border-box;
  padding: 0 32rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.03);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  color: #ffffff;
  font-size: 28rpx;
}

.form-placeholder { color: #4b5563; }

.form-code-row {
  display: flex;
  gap: 20rpx;
  align-items: stretch;
}

.form-input--code {
  flex: 1;
  font-family: 'SF Mono', Menlo, Consolas, monospace;
  letter-spacing: 8rpx;
  font-weight: 600;
}

.form-code-btn {
  flex-shrink: 0;
  height: 96rpx;
  padding: 0 32rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #6366f1, #a855f7);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  border: none;
}

.form-code-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

.form-code-btn--disabled {
  background: rgba(255, 255, 255, 0.04) !important;
  border: 1rpx solid rgba(255, 255, 255, 0.04);
  color: #4b5563 !important;
}

.form-error {
  margin-top: 24rpx;
  padding: 20rpx 28rpx;
  border-radius: 16rpx;
  background: rgba(239, 68, 68, 0.08);
  border: 1rpx solid rgba(239, 68, 68, 0.15);
  color: #f87171;
  font-size: 24rpx;
  line-height: 1.5;
}

.sheet-actions {
  margin-top: 48rpx;
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 20rpx;
}

