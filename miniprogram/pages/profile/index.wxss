/* 用户卡 */
.user-card .user-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #f0f0f0;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-fallback {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #999;
  font-weight: 600;
  background: #f0f0f0;
}

.user-meta {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.user-balance {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #999;
}

.user-balance-num {
  color: #1a1a1a;
  font-weight: 600;
}

/* 列表卡 */
.list-card {
  padding: 0 !important;
}

.list-item {
  display: flex;
  align-items: center;
  padding: 28rpx 36rpx;
  gap: 16rpx;
}

.list-item:active {
  background: #f9f9f9;
}

.list-text { flex: 1; min-width: 0; }

.list-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1a1a1a;
}

.list-title--danger {
  color: #e54545;
}

.list-sub {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.list-arrow {
  font-size: 32rpx;
  color: #ccc;
}

.legal {
  margin-top: 40rpx;
  font-size: 20rpx;
  color: #ccc;
  text-align: center;
}

/* —— Sheet —— */
.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}

.sheet {
  width: 100%;
  background: #ffffff;
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  padding: 24rpx 36rpx calc(40rpx + env(safe-area-inset-bottom));
}

.sheet-handle {
  width: 60rpx;
  height: 6rpx;
  background: #e5e5e5;
  border-radius: 3rpx;
  margin: 0 auto 24rpx;
}

.sheet-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.sheet-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}

.form-field {
  margin-top: 24rpx;
}

.form-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  box-sizing: border-box;
  padding: 0 24rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  border: none;
  color: #1a1a1a;
  font-size: 28rpx;
}

.form-placeholder { color: #ccc; }

.form-code-row {
  display: flex;
  gap: 16rpx;
  align-items: stretch;
}

.form-input--code {
  flex: 1;
  font-family: 'SF Mono', Menlo, Consolas, monospace;
  letter-spacing: 8rpx;
}

.form-code-btn {
  flex-shrink: 0;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  background: #1a1a1a;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 500;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.form-code-btn:active {
  opacity: 0.7;
}

.form-code-btn--disabled {
  background: #f0f0f0;
  color: #ccc;
}

.form-error {
  margin-top: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  background: #fff0f0;
  color: #e54545;
  font-size: 24rpx;
}

.sheet-actions {
  margin-top: 32rpx;
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 16rpx;
}
