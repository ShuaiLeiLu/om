.redeem-box {
  background-color: #fff;
  padding: 60rpx 40rpx;
  margin: 40rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.redeem-box .title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 40rpx;
}

.input-container {
  background-color: #f6f6f6;
  border-radius: 12rpx;
  padding: 20rpx 30rpx;
  margin-bottom: 40rpx;
}

.redeem-input {
  height: 60rpx;
  font-size: 32rpx;
  text-align: center;
}

.redeem-box .tips {
  font-size: 24rpx;
  color: #8a8a8a;
  text-align: center;
  margin-top: 30rpx;
  line-height: 1.6;
}

.help-box {
  padding: 0 40rpx;
}

.help-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  color: #333;
}

.help-item {
  margin-bottom: 30rpx;
}

.help-item .q {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 10rpx;
}

.help-item .a {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}
