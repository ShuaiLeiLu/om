.ledger-list {
  background-color: #fff;
}

.ledger-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.ledger-item:last-child {
  border-bottom: none;
}

.item-left .type {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.item-left .time {
  font-size: 24rpx;
  color: #8a8a8a;
  margin-bottom: 4rpx;
}

.item-left .remark {
  font-size: 24rpx;
  color: #ccc;
}

.item-right {
  text-align: right;
}

.item-right .amount {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.item-right .amount.plus {
  color: #52c41a;
}

.item-right .amount.minus {
  color: #ff4d4f;
}

.item-right .balance {
  font-size: 22rpx;
  color: #8a8a8a;
}

.load-more {
  padding: 40rpx;
  text-align: center;
  color: #8a8a8a;
  font-size: 26rpx;
}

.no-more {
  color: #ccc;
}

/* Empty State */
.empty-state {
  padding-top: 200rpx;
  text-align: center;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 40rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #8a8a8a;
}
