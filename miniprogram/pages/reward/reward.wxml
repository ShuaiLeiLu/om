<view class="container">
  <view class="reward-header">
    <view class="title">今日免费领 Token</view>
    <view class="reward-info" wx:if="{{rewardConfig}}">
      <view class="info-box">
        <text class="label">每次可领</text>
        <text class="value">{{rewardConfig.rewardTokens}} tokens</text>
      </view>
      <view class="info-box">
        <text class="label">今日剩余</text>
        <text class="value">{{rewardConfig.remainingCount}}/{{rewardConfig.dailyLimit}} 次</text>
      </view>
    </view>
  </view>

  <view class="reward-card">
    <image class="ad-placeholder" src="/images/ad-icon.png" mode="aspectFit"></image>
    <button class="btn-primary" bindtap="startAd" loading="{{loading}}" disabled="{{loading || rewardConfig.remainingCount === 0}}">
      {{rewardConfig.remainingCount === 0 ? '今日已领完' : '看广告领取'}}
    </button>
    <view class="tips">完整观看广告后可获得 token。中途关闭广告不会发放奖励。</view>
  </view>

  <view class="rules-box">
    <view class="rules-title">规则说明</view>
    <view class="rule-item">1. 完整观看视频广告即可获得奖励。</view>
    <view class="rule-item">2. 奖励 token 有有效期（通常为 7 天），请及时使用。</view>
    <view class="rule-item">3. 每天领取次数有限，零点重置。</view>
  </view>

  <!-- Recent records could go here if the API supports it -->
</view>
