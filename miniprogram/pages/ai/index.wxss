.state-title {
  font-size: 32rpx;
  font-weight: 600;
}

.state-desc {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.section-title {
  margin-top: 6rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #f8fafc;
}

.model-chip {
  max-width: 280rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  color: #c7d2fe;
  font-size: 22rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.prompt-input {
  width: 100%;
  min-height: 150rpx;
  padding: 22rpx 24rpx;
  box-sizing: border-box;
  border-radius: 24rpx;
  background: rgba(15, 23, 42, 0.62);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  color: #f8fafc;
  font-size: 26rpx;
  line-height: 1.5;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18rpx;
}

.generated-image {
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 22rpx;
  background: rgba(15, 23, 42, 0.8);
}
